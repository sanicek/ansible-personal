# Uses the Solarized theme layout with colors supplied by the terminal palette.

override_git_prompt_colors() {
  GIT_PROMPT_THEME_NAME="Flexoki"
  GIT_PROMPT_STAGED="${Yellow}●"
  GIT_PROMPT_STASHED="${BoldMagenta}⚑ "
  GIT_PROMPT_CLEAN="${Green}✔"
  GIT_PROMPT_START_USER="_LAST_COMMAND_INDICATOR_ ${BoldCyan}${PathShort}${ResetColor}"
  GIT_PROMPT_START_ROOT="${GIT_PROMPT_START_USER}"
  GIT_PROMPT_END_USER=" \n${Yellow}${Time12a}${ResetColor} $ "
  GIT_PROMPT_END_ROOT=" \n${Yellow}${Time12a}${ResetColor} # "
}

reload_git_prompt_colors "Flexoki"
