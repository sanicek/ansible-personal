# Copy this file to localhost.yml for private local overrides.
# host_vars/localhost.yml is gitignored and overrides group_vars/all.yml.
#
# Ollama model selection is managed via git-tracked presets in group_vars/all.yml.
# No preset is selected by default. Choose one at runtime:
#   ansible-playbook ... -e model_preset=qwen35_9b
# Available presets are listed in group_vars/all.yml under model_presets.

# sanicek.server.arch_ollama machine overrides:
# (GPU-specific, keep here — not part of model presets)
# arch_ollama_rocm_hsa_override_gfx_version: "12.0.0"
#
# (Firewall customization)
# arch_ollama_firewall_rules:
#   - port: "11434"
#     proto: tcp
#     rule: allow
#     from_ip: "192.168.1.0/24"
#     comment: Ollama API

